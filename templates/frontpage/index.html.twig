{% extends 'base.html.twig' %}

{% block title %}AI Bibliotek – forhåndsvisning{% endblock %}

{% block body %}
    {% if app.environment == 'dev' %}<!-- {{ _self }} -->{% endif %}
    <div class="view-root grid gap-12">

        <twig:Hero eyebrow="Del &amp; hjemtag · dansk offentlig AI">
            <twig:block name="heading">
                Et fælles bibliotek over <em class="italic text-primary">kommunale</em> AI-assistenter.
            </twig:block>
            <twig:block name="lead">
                Find, del og hjemtag AI-assistenter bygget af danske myndigheder. Når én kommune løser
                en opgave, kan resten hjemtage assistenten, eksportere konfigurationen og køre den
                lokalt — så gode løsninger skalerer nationalt.
            </twig:block>

            <twig:Stats:List>
                <twig:Stats:Item label="Assistenter"   value="{{ stats.assistants }}" />
                <twig:Stats:Item label="Kommuner"      value="{{ stats.kommuner }}" />
                <twig:Stats:Item label="Sprogmodeller" value="{{ stats.models }}" />
            </twig:Stats:List>
        </twig:Hero>

        <twig:SearchBox placeholder="Søg efter borgerservice, referat, journalisering…" />

        <twig:CardRail:Container eyebrow="Forhåndsvisning" linkLabel="Kataloget kommer →">
            {% for a in assistants %}
                <twig:CardRail:Card
                    kommune="{{ a.kommune }}"
                    model="{{ a.model }}"
                    name="{{ a.name }}"
                    summary="{{ a.summary }}" />
            {% endfor %}
        </twig:CardRail:Container>

        <twig:Box eyebrow="Sådan virker det">
            {% set steps = [
                {lead: 'Opret bruger', body: ' og log ind som repræsentant for din myndighed.'},
                {lead: 'Find en assistent', body: ' – søg og filtrér på kommune, sprogmodel og datafølsomhed.'},
                {lead: 'Hjemtag', body: ' – eksportér assistentens JSON og følg vidensopskriften, der beskriver hvilke data du selv skal levere.'},
                {lead: 'Tilpas lokalt', body: ' – importér i din egen OpenWebUI, tilføj kommunens viden og tag den i brug.'},
            ] %}
            <twig:StepList:List>
                {% for step in steps %}
                    <twig:StepList:Item index="{{ loop.index }}" lead="{{ step.lead }}" body="{{ step.body }}" />
                {% endfor %}
            </twig:StepList:List>
        </twig:Box>

    </div>
    {% if app.environment == 'dev' %}<!-- /{{ _self }} -->{% endif %}
{% endblock %}
