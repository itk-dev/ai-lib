{% props href, initials = brand_initials, name = brand_name, tagline = brand_tagline %}
<a class="flex items-center gap-3 no-underline" href="{{ href }}" aria-label="{{ 'layout.brand_aria_label'|trans }}">
    <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-ink font-display text-base font-semibold text-primary-ink" aria-hidden="true">{{ initials }}</span>
    <span class="flex flex-col leading-tight">
        <span class="font-display text-base font-semibold text-ink">{{ name }}</span>
        <span class="text-[0.78rem] uppercase tracking-[0.16em] text-text-muted">{{ tagline|raw }}</span>
    </span>
</a>
