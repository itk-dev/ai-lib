{% if app.environment == 'dev' %}<!-- {{ _self }} -->
{% endif %}<!DOCTYPE html>
<html lang="da">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}AI Bibliotek{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400;9..144,500;9..144,600;9..144,700&family=Geist:wght@400;500;600;700&display=swap">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="flex min-h-screen flex-col bg-bg text-text antialiased">
        <twig:Layout:SkipLink />

        <twig:Layout:SiteHeader>
            <twig:Nav:Menu>
                <twig:Nav:Link href="#">Katalog</twig:Nav:Link>
                <twig:Nav:Link href="#">Del assistent</twig:Nav:Link>
                <twig:Nav:Link href="#">Mine assistenter</twig:Nav:Link>
                <twig:Nav:Link href="#">Favoritter</twig:Nav:Link>
                <twig:Nav:Link href="#">Samlinger</twig:Nav:Link>
            </twig:Nav:Menu>
        </twig:Layout:SiteHeader>

        <main id="main"
              class="mx-auto w-full max-w-[1600px] flex-1 px-[clamp(20px,4vw,56px)] py-[clamp(24px,4vw,56px)]"
              tabindex="-1">
            {% block body %}{% endblock %}
        </main>

        <twig:Layout:SiteFooter linkHref="https://github.com/itk-dev/ai-lib" linkLabel="Om projektet">
            Forhåndsvisning · ingen data endnu · designet følger <a class="text-primary no-underline hover:text-primary-hover" href="https://itk-dev.github.io/research-projects/projects/ai-bibliotek/mocks/index.html#/">prototype-mockuppet</a>
        </twig:Layout:SiteFooter>
    </body>
</html>
{% if app.environment == 'dev' %}<!-- /{{ _self }} -->{% endif %}
